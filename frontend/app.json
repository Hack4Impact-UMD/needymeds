{
  "expo": {
    "name": "NeedyMeds",
    "slug": "ddc-app",
    "scheme": "needymeds",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/needymeds-adaptive-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/needymeds-adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.needymeds.ddcapp",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location data helps identify nearby assistance programs and pharmacies.",
        "NSPhotoLibraryAddUsageDescription": "Save your drug discount card to Photos for easy access at the pharmacy.",
        "NSPhotoLibraryUsageDescription": "Access your photo library to save drug discount cards.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["0A2A.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePreciseLocation",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeCoarseLocation",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": []
      }
    },
    "android": {
      "package": "org.needymeds.ddcapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/needymeds-adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/needymeds.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8aa50023-51cd-4394-824f-9e84c66c9407"
      },
      "API_BASE": "https://ddcapp-api.needymeds.org"
    },
    "updates": {
      "url": "https://u.expo.dev/8aa50023-51cd-4394-824f-9e84c66c9407"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Save your drug discount card to Photos for easy access at the pharmacy.",
          "savePhotosPermission": "Save your drug discount card to Photos for easy access at the pharmacy.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}
